  "trainingPlan": [
    {
      "title": "階段 1：開球與風中起始線",
      "items": [
        "Driver / 3W 各建立一個低失誤開球選項，前九優先用不右曲的球路。",
        "練 7i、8i 低彈道 punch shot，風中只要求起始線與落點區。",
        "用紅梯距離模擬 1、2、3、9 洞：開球後的第二桿只攻果嶺中央。"
      ]
    },
    {
      "title": "階段 2：100–135 碼得分區",
      "items": [
        "針對 5、8、12、16 洞建立 100 / 110 / 120 / 133 碼 carry 表。",
        "W、9i、8i 做半揮與四分之三揮，避免頂風硬打滿桿。",
        "par3 一律練果嶺中央與安全邊，不練短邊旗位。"
      ]
    },
    {
      "title": "階段 3：par5 三段與水池決策",
      "items": [
        "6、7、13、18 洞全部設計三桿到果嶺，不把第二桿打到最窄處。",
        "水池洞練 layup 到完整 wedge 距離，寧可 85–105 碼進攻。",
        "長推 9–12m 留 1.5m 內，讓保 bogey 的路線成立。"
      ]
    },
    {
      "title": "賽前一天",
      "items": [
        "確認當天風向與梯台，不改揮桿，只確認開球、100–135 碼與推桿手感。"
      ]
    }
  ],
  "checklist": [
    "第一洞前先確認海風方向；前九所有碼數先用風修正。",
    "紅梯作戰，若被迫白梯，目標總桿加 5–7 桿。",
    "HCP 1/2/3 洞接受雙柏忌，不為了救 par 打高風險球。",
    "後九看到水池時，先選安全落點再選球桿。",
    "par5 預設三段，只有好 lie、順風、無水壓力才考慮進攻。",
    "短 par4 可以搶分，但開球不能越過自己的穩定球路。"
  ]
}
